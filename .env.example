# Copy to .env (gitignored). Secrets stay server-side only (design doc 10.7) -- the
# browser never sees them. The provider is chosen by config so swapping is a flag change.

# --- data provider selection ---
# fixture  : deterministic synthetic chain, no network (default for dev/tests)
# yfinance : no-auth, ~15-min delayed, zero setup (fallback)
# tradier  : official API, 15-min delayed sandbox or real-time funded (primary)
OSE_PROVIDER=fixture

# --- Tradier (when OSE_PROVIDER=tradier) ---
# Sandbox base URL + token for delayed data; swap both to go real-time (design doc 7.8).
TRADIER_BASE_URL=https://sandbox.tradier.com/v1/
TRADIER_TOKEN=

# --- rates / carry defaults (design doc 7.5) ---
# Slow-moving; refresh daily. Used when the provider doesn't supply a curve.
OSE_RISK_FREE_RATE=0.04

# --- server ---
OSE_HOST=127.0.0.1
OSE_PORT=8000
OSE_CORS_ORIGINS=http://localhost:5173
